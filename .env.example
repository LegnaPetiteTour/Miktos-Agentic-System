# Copy this to .env and fill in values
# NEVER commit .env to the repository

ANTHROPIC_API_KEY=your_key_here

# ── Auth (Phase 18) ───────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true to enable single-password protection.
# Leave unset or false for local single-user operation (default — no login page).
AUTH_ENABLED=false

# Shared cockpit password (required when AUTH_ENABLED=true).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_PASSWORD=change-me

# JWT signing secret — set explicitly so sessions survive restarts.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# JWT token lifetime in minutes (default: 480 = 8 hours)
JWT_EXPIRE_MINUTES=480

# ── Docker ────────────────────────────────────────────────────────────────────
HOST_PORT=8000
# MIKTOS_DATA_DIR=/app/data   # set automatically by docker-compose

# OBS WebSocket connection — Tools → WebSocket Server Settings in OBS
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=your_obs_websocket_password_here

# ── Phase 5 — Post-Stream Closure Engine ──────────────────────────────────────

# YouTube OAuth2 (obtain via scripts/youtube_auth.py)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Required scope: https://www.googleapis.com/auth/youtube.force-ssl
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_EN=     # pre-authorized for EN channel
YOUTUBE_REFRESH_TOKEN_FR=     # pre-authorized for FR channel (may be same account)

# Google Translate REST API v2
# Obtain at: https://console.cloud.google.com/apis/credentials
GOOGLE_TRANSLATE_API_KEY=

# ElevenLabs Speech-to-Text (Scribe)
# Obtain at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Notifications (optional — leave blank to skip that channel)
TEAMS_WEBHOOK_URL=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
NOTIFICATION_FROM_EMAIL=

# ── Pearl (Epiphan) ───────────────────────────────────────────────────────────
# Channel IDs used for layout control and monitoring
PEARL_CHANNEL_EN=2
PEARL_CHANNEL_FR=3
